{
  "name": "grupresumo",
  "version": "1.0.0",
  "description": "Resumo automatico de grupos de WhatsApp e Telegram com IA + audio (ElevenLabs).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "tsx watch --node-options=\"--experimental-sqlite\" src/index.ts",
    "summarize": "tsx --node-options=\"--experimental-sqlite\" src/cli/summarize.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "form-data": "^4.0.1",
    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
