# Conexao Postgres (Vercel Marketplace -> Neon, ou qualquer Postgres)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Token usado para autorizar o endpoint /api/cron/summary (Vercel Cron envia
# Authorization: Bearer <CRON_SECRET> automaticamente).
CRON_SECRET=defina_um_segredo_longo_aleatorio

# URL publica do app (usada para registrar o webhook do Telegram).
# Em producao, a Vercel define VERCEL_URL automaticamente.
APP_URL=https://seu-dominio.vercel.app

# === Opcional: valores iniciais (a UI permite preencher tudo depois) ===
# Os campos abaixo so sao usados quando a tabela `settings` esta vazia.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_GROUPS=

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUPS=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

SUMMARY_WINDOW_HOURS=24
