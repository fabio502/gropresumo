# ===== Servidor =====
PORT=3000
DATABASE_PATH=./data/grupresumo.db
AUDIO_DIR=./data/audio

# ===== Evolution API (WhatsApp) =====
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=seu_api_key_global
EVOLUTION_INSTANCE=nome_da_instancia
# IDs dos grupos do WhatsApp (separados por virgula). Ex: 1203630xxxxx@g.us
WHATSAPP_GROUPS=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# IDs dos grupos do Telegram (separados por virgula). Ex: -1001234567890
TELEGRAM_GROUPS=

# ===== Anthropic (resumo) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ===== ElevenLabs (audio) =====
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ===== Agendamento =====
# Cron padrao: todos os dias as 20:00. Ver https://crontab.guru
SUMMARY_CRON=0 20 * * *
SUMMARY_TIMEZONE=America/Sao_Paulo
# Janela de mensagens a considerar no resumo (em horas)
SUMMARY_WINDOW_HOURS=24
